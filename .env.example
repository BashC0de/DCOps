# =============================================================================
# DCOps Copilot — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All services read from a single .env at the repo root via docker-compose.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Which backend the LLM router uses. Options: ollama (default, free, local OSS
# models) | anthropic (paid Claude API, optional extra — install with
# `uv sync --extra anthropic`). See ARCHITECTURE.md § LLM routing strategy.
LLM_BACKEND=ollama

# --- Ollama backend (default) ---
# Endpoint of the Ollama HTTP server. In docker-compose this is the service
# name; on a host install, use http://localhost:11434.
OLLAMA_HOST=http://ollama:11434

# How long Ollama keeps a model resident after the last call. "-1" = forever
# (use for the small always-on model). Default keeps loaded for 5 minutes,
# which lets RCA / vision models swap out and free RAM.
OLLAMA_KEEP_ALIVE=5m

# HTTP timeout in seconds. First call cold-loads weights, which can take a
# minute on CPU; 300s is comfortable.
OLLAMA_TIMEOUT_S=300

# Per-task models. The router picks one of these based on TaskClass:
#   CLASSIFY / SUMMARIZE / EXPLAIN / RCA (first pass)  → LLM_MODEL_FAST
#   NL_TO_SQL                                          → LLM_MODEL_CODER
#   RCA escalation, DEEP_REASONING (forced)            → LLM_MODEL_REASONING
#   DEEP_REASONING (explicit deep)                     → LLM_MODEL_DEEP
#   MULTIMODAL (Vision agent)                          → LLM_MODEL_VISION
# Pull each with: `docker exec dcops-ollama ollama pull <name>`
LLM_MODEL_FAST=llama3.2:3b
LLM_MODEL_CODER=qwen2.5-coder:3b
LLM_MODEL_REASONING=qwen2.5:7b
LLM_MODEL_DEEP=deepseek-r1:8b
LLM_MODEL_VISION=qwen2-vl:7b

# --- Quality layers (step 2; honored once those modules ship) ---
# Self-consistency sample count. Higher = better classification, slower.
LLM_QUALITY_SELF_CONSISTENCY_N=3
# Run a verifier/critic pass after the generator.
LLM_QUALITY_VERIFIER=true
# Validate LLM-emitted device IDs / metric names against Neo4j + CanonicalMetric.
LLM_QUALITY_KG_GROUND=true
# Semantic cache for repeated prompts (cosine > 0.97 → reuse).
LLM_QUALITY_CACHE=true

# --- Anthropic backend (optional escape valve) ---
# Only consulted when LLM_BACKEND=anthropic.
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# Hard ceiling on USD spend per agent per day (Anthropic backend only).
# Router stops paid calls past this; ignored when LLM_BACKEND=ollama.
LLM_DAILY_BUDGET_USD=5.00

# -----------------------------------------------------------------------------
# Site identity
# -----------------------------------------------------------------------------
# Which site this container is for. Used by ingestion, simulator, and agents
# to tag every TelemetryEvent. Set per-site in docker-compose profile overrides.
SITE_ID=frankfurt
SITE_REGION=eu-central-1
SITE_TIMEZONE=Europe/Berlin

# Central control-plane endpoint (gRPC). Site stacks connect outbound.
CONTROL_PLANE_GRPC_URL=control-plane:50051

# -----------------------------------------------------------------------------
# Databases
# -----------------------------------------------------------------------------
# TimescaleDB (telemetry hypertables). Memory caps set in docker-compose.yml.
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=dcops
TIMESCALE_USER=dcops
TIMESCALE_PASSWORD=changeme_timescale

# Neo4j Community (asset + dependency knowledge graph).
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j

# ChromaDB (incident/runbook embeddings for Forensic + Operator).
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_INCIDENTS=dcops_incidents
CHROMA_COLLECTION_RUNBOOKS=dcops_runbooks

# Redis (event bus + cache). maxmemory enforced via compose.
REDIS_URL=redis://redis:6379/0
REDIS_EVENT_DB=1

# MinIO (raw log archive — S3-compatible).
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=dcops_minio
MINIO_SECRET_KEY=changeme_minio
MINIO_BUCKET_RAW=dcops-raw
MINIO_BUCKET_ARTIFACTS=dcops-artifacts

# -----------------------------------------------------------------------------
# Agent runtime
# -----------------------------------------------------------------------------
# Confidence threshold below which Forensic escalates Haiku → Sonnet.
FORENSIC_ESCALATION_THRESHOLD=0.65

# Sentinel inference cadence (seconds). Lower = more CPU on the 16GB laptop.
SENTINEL_INFER_INTERVAL_SEC=30

# -----------------------------------------------------------------------------
# Ingestion + mocks (Week 2)
# -----------------------------------------------------------------------------
# Base URL of the in-repo mock vendor service. The four normalizers append
# /redfish/v1/Systems, /metrics/dcgm, /snmp/walk, /ipmi/sensors, /env/sensors
# to this. Bring it up with `docker compose --profile mocks up mocks`.
# When unset (or unreachable), all four normalizers gracefully no-op and the
# simulator remains the sole telemetry source.
MOCKS_BASE_URL=http://mocks:8090

# Per-source overrides (optional). Set these to point at real vendor
# endpoints in production; leave unset to use MOCKS_BASE_URL.
# REDFISH_BASE_URL=
# DCGM_EXPORTER_URL=
# IPMI_BASE_URL=
# SNMP_BASE_URL=
# ENV_BASE_URL=

# Poll cadences (seconds) per source.
REDFISH_INTERVAL_SEC=30
DCGM_INTERVAL_SEC=5
IPMI_INTERVAL_SEC=30
SNMP_INTERVAL_SEC=15
ENV_INTERVAL_SEC=10

# TimescaleDB writer batching.
INGEST_WRITER_FLUSH_MAX=500
INGEST_WRITER_FLUSH_INTERVAL_S=2.0

# Optimizer solver time limit (seconds). OR-Tools bin-packing.
OPTIMIZER_SOLVER_TIME_LIMIT_SEC=10

# Planner forecast horizon in days. 90 is the demo target.
PLANNER_HORIZON_DAYS=90

# -----------------------------------------------------------------------------
# Frontend / API
# -----------------------------------------------------------------------------
# FastAPI public URL — consumed by the Next.js dashboard.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Allowed CORS origins for the API (comma-separated).
API_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# structlog log level for Python services. INFO is dev default.
LOG_LEVEL=INFO

# OTEL collector endpoint (optional — leave blank to disable tracing).
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Demo controls
# -----------------------------------------------------------------------------
# When true, the simulator generates accelerated telemetry (1 min = 1 hour).
SIMULATOR_TIME_DILATION=false

# Seed the failure injector with a deterministic value for reproducible demos.
DEMO_RANDOM_SEED=42
